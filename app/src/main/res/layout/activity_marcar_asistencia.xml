<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/fondologintwo"
    tools:context="com.example.apacmanager.TRABAJADOR.MarcarAsistencia">

    <!-- Toolbar -->
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="0dp"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/colorPrimary"
        app:title="@string/marcar_asistencia_title"
        app:titleTextColor="@android:color/white"
        app:navigationIcon="@drawable/ic_arrow_back"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:padding="24dp"
        app:layout_constraintTop_toBottomOf="@id/toolbar"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Reloj / Hora actual -->
        <TextView
            android:id="@+id/tvHoraActual"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="08:45"
            android:textSize="48sp"
            android:textStyle="bold"
            android:textColor="@android:color/black"
            android:layout_marginTop="48dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/tvFechaActual"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Viernes, 10 de Abril 2026"
            android:textSize="16sp"
            android:textColor="@android:color/black"
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toBottomOf="@id/tvHoraActual"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Estado de asistencia -->
        <TextView
            android:id="@+id/tvEstado"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/estado_asistencia"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@android:color/black"
            android:layout_marginTop="48dp"
            app:layout_constraintTop_toBottomOf="@id/tvFechaActual"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Tarjeta grande de estado -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardEstado"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:layout_marginHorizontal="16dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="8dp"
            app:layout_constraintTop_toBottomOf="@id/tvEstado"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="32dp"
                android:gravity="center">

                <TextView
                    android:id="@+id/tvEstadoActual"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Aún no has marcado entrada"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@android:color/black"
                    android:gravity="center" />

                <TextView
                    android:id="@+id/tvHoraMarcada"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textSize="14sp"
                    android:textColor="@android:color/black"
                    android:layout_marginTop="8dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Botón Marcar Entrada -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnMarcarEntrada"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_marginHorizontal="24dp"
            android:layout_marginTop="48dp"
            android:text="@string/btn_marcar_entrada"
            android:textSize="16sp"
            app:cornerRadius="12dp"
            app:backgroundTint="@color/colorPrimary"
            app:layout_constraintTop_toBottomOf="@id/cardEstado"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Botón Marcar Salida -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnMarcarSalida"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_marginHorizontal="24dp"
            android:layout_marginTop="16dp"
            android:text="@string/btn_marcar_salida"
            android:textSize="16sp"
            app:cornerRadius="12dp"
            app:backgroundTint="@color/gray"
            app:layout_constraintTop_toBottomOf="@id/btnMarcarEntrada"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Información de tolerancia -->
        <TextView
            android:id="@+id/tvInfoTolerancia"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/info_tolerancia"
            android:textSize="14sp"
            android:textColor="@android:color/black"
            android:textAlignment="center"
            android:layout_marginTop="40dp"
            app:layout_constraintTop_toBottomOf="@id/btnMarcarSalida"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>